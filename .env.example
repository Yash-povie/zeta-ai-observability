# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=zeta_telemetry
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://admin:password@postgres:5432/zeta_telemetry

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=example_app

# Jaeger
JAEGER_API_URL=http://jaeger:16686/api/traces

# Eval Worker
EVAL_SAMPLE_RATE=0.05
EVAL_POLL_INTERVAL_SECONDS=15
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Grafana
GF_SECURITY_ADMIN_PASSWORD=admin